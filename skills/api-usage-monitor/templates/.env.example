# API Usage Monitor environment template.
# Copy this file to local/.env, then replace the example values below.
# Do not commit local/.env or paste real keys into chat.

# DeepSeek
# Get this from the DeepSeek platform API keys page.
# Used by the "DeepSeek balance" source to call /user/balance.
DEEPSEEK_API_KEY=REPLACE_WITH_SECRET

# GitHub Copilot premium request usage
# Create a token that can read Copilot premium request billing usage.
# For personal usage, set GITHUB_USERNAME. GITHUB_ORG is optional and only
# needed for organization Copilot usage. The allowance is used to calculate the
# same kind of percentage shown in Settings > Copilot; Copilot Pro is 300/month
# by default, but you can override it for another plan.
GITHUB_TOKEN=REPLACE_WITH_SECRET
GITHUB_USERNAME=your-github-username
GITHUB_ORG=
GITHUB_COPILOT_PREMIUM_REQUEST_ALLOWANCE=300

# Google / Gemini / Vertex AI
# Gemini API-key billing is read from BigQuery Cloud Billing export.
# TOTAL_BUDGET is your prepaid/monthly budget, for example 10 USD.
# GOOGLE_APPLICATION_CREDENTIALS points to a service account key JSON file so
# the monitor does not need repeated `gcloud auth login`.
# GOOGLE_CLOUD_PROJECT is the project id, not the numeric project number.
# GEMINI_BQ_* values identify the billing export table shown in BigQuery.
TOTAL_BUDGET=10.0
GOOGLE_CLOUD_PROJECT=your-google-cloud-project-id
GEMINI_BQ_PROJECT=your-bigquery-project-id
GEMINI_BQ_DATASET=your_billing_export_dataset
GEMINI_BILLING_TABLE=gcp_billing_export_v1_XXXXXX_XXXXXX_XXXXXX
GEMINI_BQ_SERVICE_FILTER=
GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account-key.json
GOOGLE_OAUTH_ACCESS_TOKEN=

# Codex Desktop local usage
# No API key is required. Leave CODEX_HOME empty to use the default
# %USERPROFILE%\.codex. Set it only if your Codex data lives elsewhere.
CODEX_HOME=
